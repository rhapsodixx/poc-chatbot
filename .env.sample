# ============================================================
# satusatu.com RAG Chatbot — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values:
#   cp .env.sample .env
# ============================================================

# ── OpenRouter (LLM Routing) ────────────────────────────────
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_PRIMARY_MODEL=google/gemini-2.5-flash
OPENROUTER_FALLBACK_MODEL=openai/gpt-4o-mini
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small

# ── ChromaDB ─────────────────────────────────────────────────
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION_NAME=satusatu_knowledge

# ── Target Website ───────────────────────────────────────────
SITE_URL=https://satusatu.com
SITEMAP_URL=https://satusatu.com/sitemap.xml

# ── Guardrail Settings ───────────────────────────────────────
SIMILARITY_THRESHOLD=0.35
MAX_RETRIEVED_CHUNKS=5

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]

# ── Debug ────────────────────────────────────────────────────
DEBUG=false
